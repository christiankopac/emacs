;;; org-roam.el --- Org-roam configuration

;; ============================================================================
;; Org-roam Configuration
;; ============================================================================

(with-eval-after-load 'org-roam
  (setq org-roam-directory "~/Sync/2_denote/roam/"              ; Roam directory
        org-roam-db-location "~/Sync/2_denote/roam/org-roam.db" ; Database location
        org-roam-db-gc-threshold most-positive-fixnum      ; Disable auto-gc
        org-roam-completion-everywhere t                   ; Enable completion everywhere
        org-roam-node-display-template (concat "${title:*} " (propertize "${tags:10}" 'face 'org-tag))
        org-roam-capture-templates
        '(("d" "default" plain "%?"
           :target (file+head "%<%Y%m%d%H%M%S>-${slug}.org"
                              "#+title: ${title}\n#+date: %U\n#+filetags: \n\n")
           :unnarrowed t)))

  ;; Enable database autosync
  (org-roam-db-autosync-mode)

  ;; Keybindings
  (global-set-key (kbd "C-c n l") 'org-roam-buffer-toggle)
  (global-set-key (kbd "C-c n f") 'org-roam-node-find)
  (global-set-key (kbd "C-c n g") 'org-roam-graph)
  (global-set-key (kbd "C-c n i") 'org-roam-node-insert)
  (global-set-key (kbd "C-c n c") 'org-roam-capture)
  (global-set-key (kbd "C-c n j") 'org-roam-dailies-capture-today))

(provide 'org-roam-config)
